PORT=3000
NODE_ENV=development

# ─── Required by backend ──────────────────────────────────────────────────────

# Session mode pooler — supports IPv4 + IPv6 (port 5432)
# Dashboard → Connect button → Session mode → copy URI
DATABASE_URL=postgres://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── Optional (needed when we add Supabase client server-side) ────────────────

# Dashboard → Settings → API → Project URL
SUPABASE_URL=https://<project-ref>.supabase.co

# New-style secret key (replaces legacy service_role JWT)
# Dashboard → Settings → API Keys → Secret keys tab
# SUPABASE_SECRET_KEY=sb_secret_...

# ─── Frontend reference (NOT used by this backend) ───────────────────────────
# Mobile app uses the publishable key (replaces legacy anon JWT)
# Dashboard → Settings → API Keys → Publishable keys tab
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ─── AI (Phase 2) ─────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
